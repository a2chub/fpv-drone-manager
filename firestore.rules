rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPublicData() {
      return resource.data.isPublic == true;
    }

    // Users collection
    match /users/{userId} {
      // Own data: read/write
      allow read, write: if isOwner(userId);
      // Admin can read all
      allow read: if isAdmin();
      // Public profiles can be read by anyone
      allow read: if resource.data.settings.isProfilePublic == true;
      // Allow updating followersCount by other authenticated users (for follow/unfollow)
      allow update: if isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']);

      // Drones subcollection
      match /drones/{droneId} {
        allow read: if isOwner(userId) ||
                       isPublicData() ||
                       isAdmin();
        allow write: if isOwner(userId);

        // Parts subcollection
        match /parts/{partId} {
          allow read: if isOwner(userId) ||
                         isPublicData() ||
                         isAdmin();
          allow write: if isOwner(userId);

          // Part histories subcollection
          match /histories/{historyId} {
            allow read: if isOwner(userId) ||
                           isPublicData() ||
                           isAdmin();
            allow write: if isOwner(userId);
          }
        }

        // Race links subcollection
        match /raceLinks/{linkId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId);
        }
      }

      // Races subcollection
      match /races/{raceId} {
        allow read: if isOwner(userId) ||
                       isPublicData() ||
                       isAdmin();
        allow write: if isOwner(userId);
      }

      // Following subcollection
      match /following/{targetUserId} {
        // Owner can read/write their following list
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      // Followers subcollection
      match /followers/{followerUserId} {
        // Anyone authenticated can read followers
        allow read: if isAuthenticated();
        // Only the follower can add/remove themselves from someone's followers
        allow write: if isAuthenticated() && request.auth.uid == followerUserId;
      }

      // Profile Comments subcollection
      match /profileComments/{commentId} {
        function isCommentAuthor() {
          return isAuthenticated() && resource.data.authorId == request.auth.uid;
        }

        function isCommentAuthorOnCreate() {
          return isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        }

        function isProfileOwner() {
          return isAuthenticated() && request.auth.uid == userId;
        }

        // Read: anyone authenticated can read non-deleted comments
        allow read: if isAuthenticated() && resource.data.isDeleted == false;
        // Profile owner can read all (including deleted for moderation)
        allow read: if isProfileOwner();
        // Create: authenticated users can create comments
        allow create: if isCommentAuthorOnCreate();
        // Update: comment author or profile owner (for soft delete)
        allow update: if isCommentAuthor() || isProfileOwner();
        // Hard delete: not allowed (use soft delete instead)
        allow delete: if false;
      }
    }

    // Public profiles collection (readable by anyone)
    match /publicProfiles/{userId} {
      // Anyone can read public profiles
      allow read: if true;
      // Only owner or admin can write
      allow write: if isOwner(userId) || isAdmin();
    }

    // Race Events collection (top-level for public search)
    match /raceEvents/{eventId} {
      // Helper to check if user is organizer
      function isOrganizer() {
        return isAuthenticated() && resource.data.organizerId == request.auth.uid;
      }

      function isOrganizerOnCreate() {
        return isAuthenticated() && request.resource.data.organizerId == request.auth.uid;
      }

      // Read: public events are readable by authenticated users, private events only by organizer
      allow read: if isAuthenticated() &&
                    (resource.data.visibility == 'public' || isOrganizer());
      // Create: authenticated users can create (must be organizer)
      allow create: if isAuthenticated() && isOrganizerOnCreate();
      // Update/Delete: only organizer
      allow update, delete: if isOrganizer();

      // Participants subcollection
      match /participants/{participantId} {
        function getEventOrganizerId() {
          return get(/databases/$(database)/documents/raceEvents/$(eventId)).data.organizerId;
        }

        function isEventOrganizer() {
          return isAuthenticated() && getEventOrganizerId() == request.auth.uid;
        }

        function isParticipantOwner() {
          return isAuthenticated() && resource.data.userId == request.auth.uid;
        }

        function isParticipantOwnerOnCreate() {
          return isAuthenticated() && request.resource.data.userId == request.auth.uid;
        }

        // Read: organizer can see all, participant can see their own
        allow read: if isEventOrganizer() || isParticipantOwner();
        // Public participants can be read by authenticated users
        allow read: if isAuthenticated() &&
                       resource.data.isPublic == true;
        // Create: authenticated users can register themselves
        allow create: if isParticipantOwnerOnCreate();
        // Update: organizer (approve/reject) or participant owner (cancel, link race)
        allow update: if isEventOrganizer() || isParticipantOwner();
        // Delete: only participant owner can delete their own
        allow delete: if isParticipantOwner();
      }

      // Posts subcollection
      match /posts/{postId} {
        function isPostAuthor() {
          return isAuthenticated() && resource.data.authorId == request.auth.uid;
        }

        function isPostAuthorOnCreate() {
          return isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        }

        // Read: authenticated users can read posts
        allow read: if isAuthenticated();
        // Create: authenticated users can create posts
        allow create: if isPostAuthorOnCreate();
        // Update/Delete: only post author
        allow update, delete: if isPostAuthor();

        // Media comments subcollection
        match /mediaComments/{commentId} {
          function isCommentAuthor() {
            return isAuthenticated() && resource.data.authorId == request.auth.uid;
          }

          function isCommentAuthorOnCreate() {
            return isAuthenticated() && request.resource.data.authorId == request.auth.uid;
          }

          // Read: authenticated users can read comments
          allow read: if isAuthenticated();
          // Create: authenticated users can create comments
          allow create: if isCommentAuthorOnCreate();
          // Update/Delete: only comment author
          allow update, delete: if isCommentAuthor();
        }
      }
    }

    // Maintenance Posts collection (top-level for public search)
    match /maintenancePosts/{postId} {
      // Helper to check if user is post author
      function isPostAuthor() {
        return isAuthenticated() && resource.data.userId == request.auth.uid;
      }

      function isPostAuthorOnCreate() {
        return isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }

      function isPostReadable() {
        return resource.data.isPublic == true || isPostAuthor();
      }

      // Read: public posts are readable by anyone, private posts only by author
      allow read: if resource.data.isPublic == true || isPostAuthor();
      // Create: authenticated users can create (must be author)
      allow create: if isPostAuthorOnCreate();
      // Update/Delete: only author
      allow update, delete: if isPostAuthor();

      // Comments subcollection
      match /comments/{commentId} {
        function isCommentAuthor() {
          return isAuthenticated() && resource.data.authorId == request.auth.uid;
        }

        function isCommentAuthorOnCreate() {
          return isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        }

        function getParentPost() {
          return get(/databases/$(database)/documents/maintenancePosts/$(postId)).data;
        }

        function isParentPostReadable() {
          let post = getParentPost();
          return post.isPublic == true || post.userId == request.auth.uid;
        }

        // Read: anyone can read if parent post is readable
        allow read: if isParentPostReadable();
        // Create: authenticated users can create comments
        allow create: if isAuthenticated() && isCommentAuthorOnCreate();
        // Update: only comment author, and only isDeleted field can be changed
        allow update: if isCommentAuthor() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'updatedAt']);
        // Hard delete: not allowed (use soft delete instead)
        allow delete: if false;
      }

      // Likes subcollection
      match /likes/{likeId} {
        function isLikeOwner() {
          return isAuthenticated() && resource.data.userId == request.auth.uid;
        }

        function isLikeOwnerOnCreate() {
          return isAuthenticated() && request.resource.data.userId == request.auth.uid;
        }

        function getParentPostForLike() {
          return get(/databases/$(database)/documents/maintenancePosts/$(postId)).data;
        }

        function isParentPostReadableForLike() {
          let post = getParentPostForLike();
          return post.isPublic == true || post.userId == request.auth.uid;
        }

        // Read: anyone can read likes if parent post is readable
        allow read: if isParentPostReadableForLike();
        // Create: authenticated users can create their own like
        allow create: if isLikeOwnerOnCreate();
        // Update: not allowed
        allow update: if false;
        // Delete: only like owner can delete their own like
        allow delete: if isLikeOwner();
      }
    }
  }
}
